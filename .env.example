# DeepLens Configuration
# Copy this file to .env and fill in the values

# ─── Mode Selection ───
# Options: "local" or "cloud"
DEEPLENS_MODE=local

# ─── Local Mode Settings ───
OLLAMA_HOST=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.2:3b
OLLAMA_REWRITER_MODEL=llama3.2:3b
JINA_CLIP_MODEL=jinaai/jina-clip-v2

# ─── Cloud Mode Settings ───
# API key is stored in OS keyring for security.
# Use: python -c "import keyring; keyring.set_password('deeplens', 'gemini_api_key', 'YOUR_KEY')"
GEMINI_EMBEDDING_MODEL=models/text-embedding-004
GEMINI_CHAT_MODEL=models/gemini-2.5-flash

# ─── PostgreSQL (Cloud Mode) ───
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=deeplens
POSTGRES_USER=deeplens
POSTGRES_PASSWORD=deeplens_dev

# ─── Application Settings ───
DEEPLENS_DATA_DIR=~/.deeplens
DEEPLENS_LOG_LEVEL=INFO
DEEPLENS_INGESTION_WORKERS=2
DEEPLENS_CHUNK_SIZE=500
DEEPLENS_CHUNK_OVERLAP=0.15
DEEPLENS_MAX_RETRIES=2
DEEPLENS_SEARCH_TOP_K=10
